# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-to-a-random-32-byte-hex-string

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=change-me-to-a-fernet-key

# Container idle timeout before reaper stops it (minutes)
IDLE_TIMEOUT_MINUTES=15

# Port pool range for per-user gurobi/mcp containers (bound to 127.0.0.1 only)
PORT_POOL_START=61100
PORT_POOL_END=61200

# DNS domain for Caddy HTTPS termination (leave blank to use "tls internal" with self-signed cert)
DOMAIN=

# SQLite database path (relative to project root)
DB_PATH=data/app.db
